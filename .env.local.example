# Copy to .env.local (gitignored) to override .env for local development.
#
# Option A — Atlas (same DB as production): whitelist your IP in
#   https://cloud.mongodb.com → Network Access → Add IP Address
# No .env.local needed if Atlas allows your IP.
#
# Option B — Local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/sandhya-final
